# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/storyliner"

# ─── LLM Provider ────────────────────────────────────────────────────────────────
# Set to "mock" for local development, "openai" for production
LLM_ADAPTER="mock"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# ─── Social Provider Mode ────────────────────────────────────────────────────────
# Set to "mock" for local development
SOCIAL_ADAPTER="mock"

# ─── Facebook / Instagram ────────────────────────────────────────────────────────
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
# Long-lived Page Access Token — get via Meta for Developers → Your App → Graph API Explorer
# (exchange a short-lived user token for a page token via /me/accounts)
FACEBOOK_PAGE_ACCESS_TOKEN=""
# Numeric Page ID — visible in Page Settings → About, or via GET /me/accounts
FACEBOOK_PAGE_ID=""
# Instagram Business Account numeric ID — GET /me/accounts?fields=instagram_business_account
INSTAGRAM_BUSINESS_ACCOUNT_ID=""

# ─── Bluesky ─────────────────────────────────────────────────────────────────────
BLUESKY_IDENTIFIER=""
BLUESKY_APP_PASSWORD=""

# ─── TikTok ──────────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_ACCESS_TOKEN=""

# ─── YouTube ─────────────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REFRESH_TOKEN=""

# ─── Twitch ──────────────────────────────────────────────────────────────────────
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
TWITCH_ACCESS_TOKEN=""

# ─── Encryption (for sensitive stream destination fields) ─────────────────────────
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
